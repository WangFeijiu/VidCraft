# Voice Studio Backend — Configuration
# Copy this file to .env and adjust paths for your system.

# Server
HOST=127.0.0.1
PORT=5050
LOG_LEVEL=INFO

# Data directories (relative to backend/ or absolute)
DATA_DIR=../data

# External tools
FFMPEG_PATH=D:/Tech/program/python/Lib/site-packages/imageio_ffmpeg/binaries/ffmpeg-win-x86_64-v7.1.exe

# AI Models
COSYVOICE_DIR=E:/视频处理/CosyVoice
HF_CACHE_DIR=E:/视频处理/.cache/huggingface

# Frontend (serves existing HTML during Phase 1)
FRONTEND_DIR=../voice_studio/templates
